---
import { landing } from '../data/landing.js';
import { switcherMarkets } from '../data/markets.js';

const { navigation } = landing;
---

<div class="nav-country" data-country-menu>
          <button class="nav-country-toggle" type="button" aria-label={navigation.marketButtonAriaLabel} title={navigation.marketButtonTitle} aria-haspopup="true" aria-expanded="false" aria-controls="country-menu" data-country-toggle>{switcherMarkets[0].flag}</button>
          <div class="country-dropdown" id="country-menu" role="menu" aria-label={navigation.marketMenuAriaLabel}>
            {switcherMarkets.map((market) => (
              <a href={market.path} role="menuitem" hreflang={market.hreflang}><span aria-hidden="true">{market.flag}</span> {market.label}</a>
            ))}
          </div>
        </div>
