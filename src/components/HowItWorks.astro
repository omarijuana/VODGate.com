---
import StepCard from './StepCard.astro';
import { landing } from '../data/landing.js';

const { howItWorks } = landing;
---
<section class="section" id="how-it-works">
  <div class="container">
    <div class="section-heading reveal">
      <p class="eyebrow">{howItWorks.eyebrow}</p>
      <h2>{howItWorks.heading}</h2>
    </div>

    <div class="steps-grid">
      {howItWorks.steps.map((step) => (
        <StepCard number={step.number} title={step.heading} description={step.text} />
      ))}
    </div>
  </div>
</section>
