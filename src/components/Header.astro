---
import MarketSwitcher from './MarketSwitcher.astro';
import { site } from '../data/site.js';
import { landing } from '../data/landing.js';

const { navigation, navLinks } = landing;
---
<header class="site-header" data-header>
    <nav class="navbar container" aria-label={navigation.ariaLabel}>
      <a class="brand" href="#home" aria-label={navigation.brandAriaLabel}>
        <span class="brand-mark">{site.brandMark}</span>
        <span>{site.brandName}</span>
      </a>

      <button class="nav-toggle" type="button" aria-label={navigation.menuButtonAriaLabel} aria-expanded="false" data-nav-toggle>
        <span></span>
        <span></span>
        <span></span>
      </button>

      <div class="nav-menu" data-nav-menu>
        {navLinks.map((link) => (
          <a href={link.href}>{link.label}</a>
        ))}
        <MarketSwitcher />
      </div>
    </nav>
  </header>
