---
const { title, label, items, featured = false, badge } = Astro.props;
const className = featured ? 'price-card featured reveal' : 'price-card reveal';
const orderUrl = 'https://wa.me/212642197277?text=Hello%20VODGate%2C%20I%20want%20to%20order%20an%20IPTV%20plan';
---
<article class={className}>
  {badge && <span class="badge">{badge}</span>}
  <h3>{title}</h3>
  <p class="price-label">{label}</p>
  <ul>
    {items.map((item) => (
      <li>{item}</li>
    ))}
  </ul>
  <a class="btn btn-primary" href={orderUrl} target="_blank" rel="noopener">Order on WhatsApp</a>
</article>
