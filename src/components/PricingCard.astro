---
const { title, label, items, featured = false, badge, actionLabel, actionHref } = Astro.props;
const className = featured ? 'price-card featured reveal' : 'price-card reveal';
---
<article class={className}>
  {badge && <span class="badge">{badge}</span>}
  <h3>{title}</h3>
  <p class="price-label">{label}</p>
  <ul>
    {items.map((item) => (
      <li>{item}</li>
    ))}
  </ul>
  <a class="btn btn-primary" href={actionHref} target="_blank" rel="noopener">{actionLabel}</a>
</article>
