---
import { landing } from '../data/landing.js';

const { contactCta } = landing;
const [contactTextBeforeEmail, contactTextAfterEmail = ''] = contactCta.text.split(contactCta.email);
const contactEmailHref = `mailto:${contactCta.email}`;
---

<section class="section contact-section" id="contact">
  <div class="container contact-card reveal">
    <div>
      <p class="eyebrow">{contactCta.eyebrow}</p>
      <h2>{contactCta.heading}</h2>
      <p>{contactTextBeforeEmail}<a href={contactEmailHref}>{contactCta.email}</a>{contactTextAfterEmail}</p>
    </div>
    <a class="btn btn-primary" href={contactCta.actionHref} target="_blank" rel="noopener">{contactCta.actionLabel}</a>
  </div>
</section>
