---
import PricingCard from './PricingCard.astro';
import { landing } from '../data/landing.js';

const { pricing } = landing;
---
<section class="section pricing-section" id="pricing">
  <div class="container">
    <div class="section-heading reveal">
      <p class="eyebrow">{pricing.eyebrow}</p>
      <h2>{pricing.heading}</h2>
      <p>{pricing.text}</p>
    </div>

    <div class="pricing-grid">
      {pricing.plans.map((plan) => (
        <PricingCard
          title={plan.heading}
          label={plan.label}
          items={plan.features}
          featured={plan.featured}
          badge={plan.badge}
          actionLabel={plan.actionLabel}
          actionHref={plan.actionHref}
        />
      ))}
    </div>
  </div>
</section>
