---
import HeroTvPreview from './HeroTvPreview.astro';
---
<section class="hero section" id="home">
      <div class="hero-glow hero-glow-one" aria-hidden="true"></div>
      <div class="hero-glow hero-glow-two" aria-hidden="true"></div>

      <div class="container hero-grid">
        <div class="hero-content reveal">
          <p class="eyebrow">vodgate.com</p>
          <h1>VODGate - Premium IPTV &amp; VOD Services</h1>
          <p class="hero-text">A clean, reliable Live TV &amp; VOD entertainment service made for modern homes and compatible with popular devices.</p>

          <div class="hero-actions">
            <a class="btn btn-primary" href="https://wa.me/212642197277?text=Hello%20VODGate%2C%20I%20want%20to%20order%20an%20IPTV%20plan" target="_blank" rel="noopener">Order on WhatsApp</a>
            <a class="btn btn-secondary" href="#pricing">View Plans</a>
          </div>

          <div class="trust-row" aria-label="Service highlights">
            <span>Fast activation</span>
            <span>4K ready</span>
            <span>WhatsApp support</span>
          </div>
        </div>

        <HeroTvPreview />
      </div>
    </section>
