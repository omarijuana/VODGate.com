---
import HeroTvPreview from './HeroTvPreview.astro';
import { landing } from '../data/landing.js';

const { hero, trustBadges } = landing;
---
<section class="hero section" id="home">
      <div class="hero-glow hero-glow-one" aria-hidden="true"></div>
      <div class="hero-glow hero-glow-two" aria-hidden="true"></div>

      <div class="container hero-grid">
        <div class="hero-content reveal">
          <p class="eyebrow">{hero.eyebrow}</p>
          <h1>{hero.heading}</h1>
          <p class="hero-text">{hero.text}</p>

          <div class="hero-actions">
            <a class="btn btn-primary" href={hero.primaryAction.href} target="_blank" rel="noopener">{hero.primaryAction.label}</a>
            <a class="btn btn-secondary" href={hero.secondaryAction.href}>{hero.secondaryAction.label}</a>
          </div>

          <div class="trust-row" aria-label={hero.ariaLabel}>
            {trustBadges.map((badge) => (
              <span>{badge}</span>
            ))}
          </div>
        </div>

        <HeroTvPreview />
      </div>
    </section>
